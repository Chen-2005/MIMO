# App
APP_NAME=MiMo TTS Platform
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/mimo_tts

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Object Storage (S3-compatible)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=mimo-tts-audio
S3_REGION=us-east-1

# MiMo TTS Provider
MIMO_API_BASE=
MIMO_API_KEY=

# Phase 1 additions
PROVIDER_MODE=mock
LOCAL_STORAGE_PATH=./storage
TASK_DEFAULT_USER_ID=1
CELERY_ENABLED=false
