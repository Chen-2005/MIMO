# App
APP_NAME=MiMo TTS Platform
DEBUG=true
SECRET_KEY=replace-with-a-random-secret-key

# Database
DATABASE_URL=mysql+aiomysql://appuser:app-password@localhost:3306/mimo_tts

# Docker Compose local development defaults
MYSQL_ROOT_PASSWORD=dev-root-password
MYSQL_DATABASE=mimo_tts
MYSQL_USER=mimo
MYSQL_PASSWORD=dev-mimo-password

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Object Storage (S3-compatible)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=mimo-tts-audio
S3_REGION=us-east-1

# MiMo TTS Provider
MIMO_API_BASE=
MIMO_API_KEY=

# Phase 1 additions
PROVIDER_MODE=mock
LOCAL_STORAGE_PATH=./storage
TASK_DEFAULT_USER_ID=1
CELERY_ENABLED=false
